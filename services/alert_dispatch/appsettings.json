{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=TextileMonitoring;User Id=sa;Password=YourPassword123!;TrustServerCertificate=True;"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "PrefetchCount": 16,
    "RetryCount": 3,
    "RetryIntervalMs": 1000
  },
  "Database": {
    "CommandTimeout": 120,
    "MaxRetryCount": 5,
    "MaxRetryDelaySec": 10,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false
  },
  "Notifications": {
    "DingTalk": {
      "Webhook": "https://oapi.dingtalk.com/robot/send?access_token=your_token_here",
      "Secret": "your_secret_here",
      "EnableAtAll": false,
      "AtMobiles": []
    },
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "User": "alert@example.com",
      "Password": "your_password",
      "EnableSsl": true,
      "FromAddress": "alert@example.com",
      "FromDisplayName": "织绣品监测系统"
    },
    "EmailRecipients": [
      "admin@example.com",
      "operator@example.com"
    ],
    "CooldownMinutes": 60
  },
  "AlertDispatch": {
    "Templates": {
      "DingTalkTitleTemplate": "【{AlertLevel}】{Title}",
      "DingTalkBodyTemplate": "### {Title}\n\n**告警级别**: {AlertLevel}\n**文物名称**: {TextileName}\n**告警类型**: {AlertType}\n\n**当前值**: {ActualValue}\n**阈值**: {Threshold}\n\n**描述**: {Description}\n\n**建议**: {Recommendation}\n\n**时间**: {Timestamp:yyyy-MM-dd HH:mm:ss}",
      "EmailSubjectTemplate": "[{AlertLevel}] {Title} - {TextileName}",
      "EmailBodyTemplate": "<!DOCTYPE html>\n<html>\n<head>\n    <meta charset=\"utf-8\" />\n    <title>{Title}</title>\n    <style>\n        body { font-family: 'Microsoft YaHei', Arial, sans-serif; }\n        .alert-box { padding: 20px; border-radius: 8px; margin-bottom: 20px; }\n        .critical { background-color: #fee2e2; border-left: 4px solid #dc2626; }\n        .high { background-color: #fed7aa; border-left: 4px solid #ea580c; }\n        .medium { background-color: #fef3c7; border-left: 4px solid #d97706; }\n        .low { background-color: #dbeafe; border-left: 4px solid #2563eb; }\n        .label { font-weight: bold; color: #374151; }\n        .value { color: #111827; }\n    </style>\n</head>\n<body>\n    <div class=\"alert-box {AlertLevelClass}\">\n        <h2>{Title}</h2>\n        <p><span class=\"label\">告警级别:</span> <span class=\"value\">{AlertLevel}</span></p>\n        <p><span class=\"label\">文物名称:</span> <span class=\"value\">{TextileName}</span></p>\n        <p><span class=\"label\">告警类型:</span> <span class=\"value\">{AlertType}</span></p>\n        <p><span class=\"label\">当前值:</span> <span class=\"value\">{ActualValue}</span></p>\n        <p><span class=\"label\">阈值:</span> <span class=\"value\">{Threshold}</span></p>\n        <p><span class=\"label\">描述:</span> <span class=\"value\">{Description}</span></p>\n        <p><span class=\"label\">建议:</span> <span class=\"value\">{Recommendation}</span></p>\n        <p><span class=\"label\">时间:</span> <span class=\"value\">{Timestamp:yyyy-MM-dd HH:mm:ss}</span></p>\n    </div>\n</body>\n</html>"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "MassTransit": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
