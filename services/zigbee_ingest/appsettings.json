
{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "MassTransit": "Information",
        "ZigBeeIngest.Worker": "Information"
      }
    }
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest",
    "PrefetchCount": 16,
    "RetryCount": 3,
    "RetryIntervalMs": 1000
  },
  "Udp": {
    "ListenPort": 8684,
    "ReceiveTimeoutMs": 5000,
    "MulticastGroup": "239.255.86.84",
    "EnableMulticast": true
  },
  "Batching": {
    "BatchSize": 50,
    "FlushIntervalMs": 10000
  }
}
