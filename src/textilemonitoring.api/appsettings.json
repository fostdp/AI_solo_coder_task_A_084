
{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information",
      "TextileMonitoring": "Debug",
      "MassTransit": "Information"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=${DB_HOST:localhost},${DB_PORT:1433};Database=${DB_NAME:TextileMonitoringDB};User Id=${DB_USER:sa};Password=${DB_PASSWORD:YourPassword123!};TrustServerCertificate=True;MultipleActiveResultSets=True;Connect Timeout=30;"
  },

  "RabbitMQ": {
    "Host": "${RABBIT_HOST:localhost}",
    "Port": ${RABBIT_PORT:5672},
    "VirtualHost": "${RABBIT_VHOST:/}",
    "Username": "${RABBIT_USER:guest}",
    "Password": "${RABBIT_PASSWORD:guest}",
    "Heartbeat": 30,
    "PrefetchCount": 16,
    "RetryCount": 3,
    "CircuitBreakerThreshold": 10
  },

  "PopulationModel": {
    "GrowthRateR": ${LOTKA_R:0.05},
    "CarryingCapacityK": ${LOTKA_K:12.0},
    "PredationAlpha": ${LOTKA_ALPHA:0.35},
    "ConversionBeta": ${LOTKA_BETA:0.02},
    "MortalityDelta": ${LOTKA_DELTA:0.08},
    "PredatorCarryingCapacityKp": ${LOTKA_KP:2.5},
    "InitialPredatorDensity": ${LOTKA_P0:0.15},
    "TemperatureSensitivity": ${LOTKA_TEMP_SENS:0.06},
    "HumiditySensitivity": ${LOTKA_HUM_SENS:0.025},
    "SynergyInteractionPhi": ${LOTKA_PHI:1.35},
    "OdeMinStep": ${ODE_MIN_STEP:0.005},
    "OdeMaxStep": ${ODE_MAX_STEP:0.5},
    "OdeDivergenceThreshold": ${ODE_DIV_THRESH:0.5}
  },

  "MildewModel": {
    "DefaultGrowthRateRho": ${GOMPERTZ_RHO:0.015},
    "DefaultCarryingCapacityKf": ${GOMPERTZ_KF:500.0},
    "DefaultInitialCFU": ${GOMPERTZ_Y0:100.0},
    "DefaultHorizonDays": ${GOMPERTZ_HORIZON:30},
    "MoldDetectionThreshold": ${MOLD_THRESHOLD:200.0},
    "CriticalThreshold": ${MOLD_CRITICAL:300.0},
    "TemperatureSensitivity": ${GOMPERTZ_TEMP_SENS:0.06},
    "HumiditySensitivity": ${GOMPERTZ_HUM_SENS:0.025},
    "SynergyInteractionPhi": ${GOMPERTZ_PHI:1.3},
    "AggregationWindowMinutes": ${MOLD_WINDOW:10},
    "MinAggregationSamples": ${MOLD_MIN_SAMPLES:3}
  },

  "AlertSettings": {
    "HoleDensityThreshold": ${HOLE_DENSITY_THRESH:5.0},
    "FungiCFUThreshold": ${FUNGI_CFU_THRESH:300.0},
    "SynergyRiskThreshold": ${SYNERGY_THRESH:50.0},
    "WarningHoleDensity": ${WARN_HOLE:3.0},
    "WarningFungiCFU": ${WARN_FUNGI:200.0},

    "DingTalkWebhook": "${DINGTALK_WEBHOOK:https://oapi.dingtalk.com/robot/send?access_token=YOUR_ACCESS_TOKEN}",
    "DingTalkSecret": "${DINGTALK_SECRET:YOUR_SECRET}",
    "DingTalkAtMobiles": "${DINGTALK_MOBILES:}",

    "SmtpHost": "${SMTP_HOST:smtp.example.com}",
    "SmtpPort": ${SMTP_PORT:587},
    "SmtpUser": "${SMTP_USER:alerts@example.com}",
    "SmtpPassword": "${SMTP_PASSWORD:YOUR_PASSWORD}",
    "SmtpEnableSsl": ${SMTP_SSL:true},
    "SmtpFromName": "${SMTP_FROM:织绣品监测系统}",
    "EmailRecipients": "${EMAIL_RECIPIENTS:admin@example.com;curator@example.com}",

    "CriticalChannels": "${CRITICAL_CHANNELS:dingtalk,email}",
    "HighChannels": "${HIGH_CHANNELS:dingtalk}",
    "MediumChannels": "${MEDIUM_CHANNELS:email}",
    "LowChannels": "${LOW_CHANNELS:}",

    "RetryCount": ${ALERT_RETRY:3},
    "RetryIntervalSeconds": ${ALERT_RETRY_INTERVAL:60},
    "DeadLetterQueue": "${ALERT_DLQ:textile.alert_dispatch.dlq}"
  },

  "ZigBeeIngest": {
    "UdpListenPort": ${ZIGBEE_PORT:8684},
    "UdpReceiveTimeoutMs": ${ZIGBEE_TIMEOUT:5000},
    "BatchSize": ${ZIGBEE_BATCH:50},
    "FlushIntervalMs": ${ZIGBEE_FLUSH:10000},
    "MulticastGroup": "${ZIGBEE_MCAST:239.255.86.84}",
    "EnableMulticast": ${ZIGBEE_MCAST_ENABLE:true},
    "DeduplicateWindowSeconds": ${ZIGBEE_DEDUP:300}
  },

  "PredictionWindow": {
    "WindowMinutes": ${PRED_WINDOW:10},
    "MinDataPoints": ${PRED_MIN_POINTS:3},
    "MaxBatchSize": ${PRED_MAX_BATCH:100},
    "AutoTriggerThreshold": ${PRED_TRIGGER:0.2},
    "DefaultHorizonDays": ${PRED_HORIZON:30}
  },

  "Gateway": {
    "BaseUrl": "${GATEWAY_URL:http://localhost:5000}",
    "CorsOrigins": "${CORS_ORIGINS:*}",
    "RequestTimeoutSeconds": ${GATEWAY_TIMEOUT:30},
    "EnableSwagger": ${ENABLE_SWAGGER:true},
    "EnableDetailedErrors": ${ENABLE_ERRORS:false},
    "RateLimiting": {
      "PerMinute": ${RATE_LIMIT:120},
      "Burst": ${RATE_BURST:20}
    }
  }
}
